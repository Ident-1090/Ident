{
  "name": "ident",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@10.29.2",
  "scripts": {
    "dev": "vite",
    "dev:demo": "VITE_IDENT_DEMO=true vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "pnpm check-ident-schemas && vitest run",
    "test:watch": "vitest",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "generate-ident-schemas": "node scripts/generate-ident-schema-types.mjs",
    "check-ident-schemas": "node scripts/generate-ident-schema-types.mjs --check",
    "generate-pwa-assets": "pwa-assets-generator",
    "prepare": "cd .. && husky ident/.husky"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,jsonc,css}": [
      "biome check --write --no-errors-on-unmatched --files-ignore-unknown=true"
    ]
  },
  "dependencies": {
    "cmdk": "^1.1.1",
    "country-flag-icons": "^1.6.20",
    "fzstd": "^0.1.1",
    "lucide-react": "^1.23.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "ts-pattern": "^5.9.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.2",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vite-pwa/assets-generator": "^1.0.2",
    "@vitejs/plugin-react": "^6.0.3",
    "ajv": "^8.20.0",
    "husky": "9.1.7",
    "jsdom": "^29.1.1",
    "json-schema-to-typescript": "^15.0.4",
    "lint-staged": "17.0.8",
    "maplibre-gl": "^5.24.0",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.10"
  }
}
