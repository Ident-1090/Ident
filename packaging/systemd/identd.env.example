# Ident service configuration.
#
# Keep the default localhost bind when a reverse proxy on the same host is
# serving Ident to browsers. Use :8080 or a LAN address only for intentional
# direct network access.
IDENT_ADDR=127.0.0.1:8080

# Leave unset to auto-detect common receiver runtime directories. Set this when
# your receiver writes aircraft.json somewhere else.
# IDENT_DATA_DIR=/run/readsb

# Receiver file names. Change these only when your receiver writes different
# names inside IDENT_DATA_DIR.
IDENT_AIRCRAFT_FILE=aircraft.json
IDENT_RECEIVER_FILE=receiver.json
IDENT_STATS_FILE=stats.json
IDENT_OUTLINE_FILE=outline.json

# GitHub release notification only. identd never installs updates.
IDENT_UPDATE_CHECK=true
IDENT_UPDATE_REPO=Ident-1090/Ident
IDENT_UPDATE_INTERVAL_SEC=86400

# identd keeps recent aircraft trails in memory and writes a compressed restart
# cache so normal service restarts do not erase the visible trail history.
IDENT_TRAILS_MEMORY_WINDOW_SEC=7200
IDENT_TRAILS_SNAPSHOT_WINDOW_SEC=600
IDENT_TRAILS_SAMPLE_INTERVAL_SEC=5
IDENT_TRAILS_BACKFILL_MAX_WINDOW_SEC=7200
IDENT_TRAILS_BACKFILL_MAX_POINTS=100000
IDENT_TRAILS_RESTART_CACHE=true
IDENT_TRAILS_RESTART_CACHE_DIR=/var/cache/ident
IDENT_TRAILS_RESTART_CACHE_INTERVAL_SEC=60

# Longer replay history is off by default because it writes finalized blocks to
# disk. If enabled, the directory, retention, and byte budget are required.
# IDENT_REPLAY_ENABLE=true
# IDENT_REPLAY_DIR=/var/lib/ident/replay
# IDENT_REPLAY_RETENTION_SEC=259200
# IDENT_REPLAY_MAX_BYTES=524288000
# IDENT_REPLAY_BLOCK_SEC=300
# IDENT_REPLAY_SAMPLE_INTERVAL_SEC=5
